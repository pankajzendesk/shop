# PhonePe UPI Payment Gateway Configuration
# ============================================

# PhonePe Merchant ID (provided by PhonePe)
PHONEPE_MERCHANT_ID=your_merchant_id_here

# PhonePe API Key (provided by PhonePe)
PHONEPE_API_KEY=your_api_key_here

# PhonePe Environment: 'sandbox' for testing, 'production' for live
# Default: sandbox
PHONEPE_ENV=sandbox

# Base URL for payment callbacks and redirects
# Make sure this matches your domain in production
NEXT_PUBLIC_BASE_URL=http://localhost:4028

# Database URL (existing)
DATABASE_URL="postgresql://user:password@localhost:5432/shop"

# Other existing environment variables...
